Function RegisterSockets()
    RegisterGlobalFunction("string DottedIP(int IP)", @DottedIP)
    RegisterGlobalFunction("int CountHostIPs(string hostName)", @CountHostIPs)
    RegisterGlobalFunction("int HostIP(int hostIndex)", @HostIP)

    RegisterStreamSubtype("UDPStream")
    RegisterObjectMethod("UDPStream", "void Close()", @CloseUDPStream)
    RegisterObjectMethod("UDPStream", "void SendMsg(int destIp, int destPort=0)", @SendUDPMsg)
    RegisterObjectMethod("UDPStream", "int RecvMsg()", @RecvUDPMsg)
    RegisterObjectMethod("UDPStream", "int get_IP() const property", @UDPStreamIP)
    RegisterObjectMethod("UDPStream", "int get_Port() const property", @UDPStreamPort)
    RegisterObjectMethod("UDPStream", "int get_MsgIP() const property", @UDPMsgIP)
    RegisterObjectMethod("UDPStream", "int get_MsgPort() const property", @UDPMsgPort)

    Local ns$ = GetDefaultNamespace()
    If ns <> "" Then SetDefaultNamespace(ns + "::UDP") Else SetDefaultNamespace("UDP")
    RegisterGlobalFunction("UDPStream@ CreateStream(int port=0)", @CreateUDPStream)
    RegisterGlobalFunction("void SetTimeout(int recvTimeout)", @UDPTimeouts)
    SetDefaultNamespace(ns)

    RegisterStreamSubtype("TCPStream")
    RegisterObjectMethod("TCPStream", "void Close()", @CloseTCPStream)
    RegisterObjectMethod("TCPStream", "int get_IP() const property", @TCPStreamIP)
    RegisterObjectMethod("TCPStream", "int get_Port() property", @TCPStreamPort)

    RegisterType("TCPServer")
    RegisterObjectMethod("TCPServer", "void Close()", @CloseTCPServer)
    RegisterObjectMethod("TCPServer", "TCPStream@ Accept()", @AcceptTCPStream)

    If ns <> "" Then SetDefaultNamespace(ns + "::TCP") Else SetDefaultNamespace("TCP")
    RegisterGlobalFunction("TCPStream@ OpenStream(string server, int serverPort, int localPort=0)", @OpenTCPStream)
    RegisterGlobalFunction("TCPServer@ CreateServer(int port)", @CreateTCPServer)
    RegisterGlobalFunction("void SetTimeouts(int readMillis, int acceptMillis)", @TCPTimeouts)
    SetDefaultNamespace(ns)

    RegisterGlobalFunction("string GetDomainTXT(string domain)", @GetDomainTXT)
    RegisterGlobalFunction("string ParseDomainTXT(string txt, string name)", @ParseDomainTXT)

    RegisterGlobalFunction("int DownloadFile(string url, string file)", @DownloadFile)
End Function

Function RegisterStreamSubtype(name$, isActualSubType%=True)
    RegisterType(name)
    RegisterObjectMethod(name, "int get_IsEOF() const property", @Eof)
    RegisterObjectMethod(name, "int get_IsReadAvail() const property", @ReadAvail)
    RegisterObjectMethod(name, "int ReadByte()", @ReadByte)
    RegisterObjectMethod(name, "int ReadShort()", @ReadShort)
    RegisterObjectMethod(name, "int ReadInt()", @ReadInt)
    RegisterObjectMethod(name, "float ReadFloat()", @ReadFloat)
    RegisterObjectMethod(name, "string ReadString()", @ReadString)
    RegisterObjectMethod(name, "string ReadLine()", @ReadLine)
    RegisterObjectMethod(name, "void WriteByte(int value)", @WriteByte)
    RegisterObjectMethod(name, "void WriteShort(int value)", @WriteShort)
    RegisterObjectMethod(name, "void WriteInt(int value)", @WriteInt)
    RegisterObjectMethod(name, "void WriteFloat(float value)", @WriteFloat)
    RegisterObjectMethod(name, "void WriteString(string value)", @WriteString)
    RegisterObjectMethod(name, "void WriteLine(string value)", @WriteLine)
    RegisterObjectMethod(name, "void CopyTo(Stream@ destStream, int bufferSize=16384)", @CopyStream)

    If isActualSubType Then
        RegisterTypeInheritance(name, "Stream")
    End If
End Function

Function RegisterStream()
    RegisterStreamSubtype("Stream", False)
End Function

Function RegisterString()
    RegisterGlobalFunction("string CurrentDate()", @CurrentDate)
    RegisterGlobalFunction("string CurrentTime()", @CurrentTime)
End Function

Global HasRegisteredEngine%
Function RegisterEngine()
    If HasRegisteredEngine Then Return
    HasRegisteredEngine = True
    
    SetDefaultNamespace("B3D")
    RegisterGlobalFunction("void DebugLogRuntimeStats()", @RuntimeStats)
    RegisterStream()
    RegisterAudio()
    RegisterBank()
    RegisterGraphics()
    RegisterB3D()
    ;RegisterFilesystem()
    RegisterInput()
    RegisterMath()
    RegisterRuntime()
    ;RegisterSockets()
    RegisterString()
    SetDefaultNamespace("")
End Function

RegisterEngine()

