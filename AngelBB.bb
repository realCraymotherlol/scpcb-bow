Function RegisterAudio()
    RegisterType("Channel")
    RegisterObjectMethod("Channel", "void Stop()", @StopChannel)
    RegisterObjectMethod("Channel", "void Pause()", @PauseChannel)
    RegisterObjectMethod("Channel", "void Resume()", @ResumeChannel)
    RegisterObjectMethod("Channel", "void SetPitch(int pitch)", @ChannelPitch)
    RegisterObjectMethod("Channel", "void SetVolume(float volume)", @ChannelVolume)
    RegisterObjectMethod("Channel", "void SetPan(float pan)", @ChannelPan)
    RegisterObjectMethod("Channel", "int get_IsPlaying() const property", @ChannelPlaying)

    RegisterType("Sound")
    RegisterObjectMethod("Sound", "void Free()", @FreeSound)
    RegisterObjectMethod("Sound", "Channel@ Play()", @PlaySound)
    RegisterObjectMethod("Sound", "void Loop()", @LoopSound)
    RegisterObjectMethod("Sound", "void SetPitch(int pitch)", @SoundPitch)
    RegisterObjectMethod("Sound", "void SetVolume(float volume)", @SoundVolume)
    RegisterObjectMethod("Sound", "void SetPan(float pan)", @SoundPan)

    RegisterGlobalFunction("Channel@ PlayMusic(string midifile, int mode=0)", @PlayMusic)

    Local ns$ = GetDefaultNamespace()
    If ns <> "" Then SetDefaultNamespace(ns + "::Sound") Else SetDefaultNamespace("Sound")
    ;RegisterGlobalFunction("Sound@ Load(string filename)", @LoadSound)
    ;RegisterGlobalFunction("Sound@ Load3D(string filename)", @Load3DSound)
    SetDefaultNamespace(ns)
End Function

